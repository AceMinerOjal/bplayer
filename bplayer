#!/bin/zsh
# bplayer - Unified mpv player control script for Arch Linux
# Usage: bplayer [command]

set -eu

# Configuration via environment variables (with defaults)
SOCKET="${BPLAYER_SOCKET:-${XDG_RUNTIME_DIR:-/tmp}/mpvsocket}"
DEFAULT_IMG="${BPLAYER_DEFAULT_IMG:-/usr/local/share/bplayer/no-image-found.svg}"
MUSIC_DIR="${BPLAYER_MUSIC_DIR:-$HOME/Music}"

zmodload zsh/net/socket

# Check if mpv is running and socket exists
cmd_check() {
    pgrep -x mpv >/dev/null || { dunstify -a "mpv-control" -u critical "mpv Error" "mpv is not running."; return 1; }
    [[ -S "$SOCKET" ]] || { dunstify -a "mpv-control" -u critical "mpv Error" "No IPC socket found."; return 1; }
}

# Send command to mpv via IPC socket
mpv_send() {
    local fd response
    zsocket "$SOCKET" 2>/dev/null || return 1
    fd=$REPLY
    print -u$fd "$1"
    if read -u $fd response; then
        print -r "$response"
    fi
    exec {fd}>&-
}

# Wait for socket to be created (max 2 seconds)
socket_wait() {
    local attempt=0
    while [[ ! -S "$SOCKET" && $attempt -lt 20 ]]; do
        sleep 0.1
        ((attempt++))
    done
    [[ -S "$SOCKET" ]] || return 1
}

# Wait for playlist to be loaded (max 5 seconds)
wait_for_playlist() {
    local attempt=0 playlist
    while [[ $attempt -lt 50 ]]; do
        playlist=$(mpv_send '{"command": ["get_property", "playlist"]}' 2>/dev/null)
        if [[ -n "$playlist" ]] && echo "$playlist" | jq -e '.data | length > 0 and .[0].filename != null' >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.1
        ((attempt++))
    done
    return 1
}

# Show playlist directory selector
select_playlist_dir() {
    find "$MUSIC_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort | tofi --prompt-text "Select playlist: "
}

# Get loop status (internal helper)
_get_loop_status() {
    local loop_file loop_playlist
    loop_file=$(mpv_send '{"command": ["get_property", "loop-file"]}' 2>/dev/null | jq -r '.data // "no"')
    loop_playlist=$(mpv_send '{"command": ["get_property", "loop-playlist"]}' 2>/dev/null | jq -r '.data // "false"')
    print "$loop_file|$loop_playlist"
}

# Get loop status indicators for menu display
get_loop_indicators() {
    local loop_data loop_file loop_playlist file_ind="" playlist_ind=""
    loop_data=$(_get_loop_status)
    loop_file="${loop_data%%|*}"
    loop_playlist="${loop_data##*|}"
    [[ "$loop_file" != "no" && "$loop_file" != "false" ]] && file_ind=" ’ĆĪ"
    [[ "$loop_playlist" != "false" && "$loop_playlist" != "0" ]] && playlist_ind=" ’Ć×"
    print "$file_ind|$playlist_ind"
}

# Build loop suffix for notifications
get_loop_suffix() {
    [[ -S "$SOCKET" ]] || { return; }
    local loop_data loop_file loop_playlist suffix=""
    loop_data=$(_get_loop_status)
    loop_file="${loop_data%%|*}"
    loop_playlist="${loop_data##*|}"
    [[ "$loop_file" != "no" && "$loop_file" != "false" ]] && suffix+=" ’ĆĪ"
    [[ "$loop_playlist" != "false" && "$loop_playlist" != "0" ]] && suffix+=" ’Ć×"
    print "$suffix"
}

# Launch mpv with playlist selection, then open track selector
cmd_start() {
    local selected
    selected=$(select_playlist_dir)
    [[ -z "$selected" ]] && exit 0

    pkill mpv 2>/dev/null || true
    rm -f "$SOCKET" 2>/dev/null || true

    mpv --no-video --input-ipc-server="$SOCKET" "$MUSIC_DIR/$selected/" 2>/dev/null &
    socket_wait || { dunstify -a "mpv-control" -u critical "mpv Error" "Socket not created."; exit 1; }
    wait_for_playlist || { dunstify -a "mpv-control" -u critical "mpv Error" "Playlist not loaded."; exit 1; }

    cmd_select
}

# Show playback control menu
cmd_actions() {
    cmd_check || exit 1

    local loop_status loop_file_ind loop_playlist_ind
    loop_status=$(get_loop_indicators)
    loop_file_ind="${loop_status%%|*}"
    loop_playlist_ind="${loop_status##*|}"

    local selected
    selected=$(printf '%s\n' "’üŗ Toggle Play/Pause" "¾░Æ« Previous Track" "¾░ÆŁ Next Track" "’Ć© Volume +10%" "’Ć¦ Volume -10%" "’Ć” Mute/Unmute" "’ēå Speed -0.25x" "’ēå Speed +0.25x" "’Ć× Reset Speed" "${loop_file_ind} Loop Track" "${loop_playlist_ind} Loop Playlist" "’Ćæ Stop" "’üĀ Seek -10s" "’üĪ Seek +10s" "¾░æÉ Seek -1min" "¾░æö Seek +1min" "’ĆĪ Restart Track" "¾░ōĆ Toggle Shuffle" "’äŠ Show Playlist" "’ĆĢ Change" \
        | tofi --prompt-text "Select action: ")

    case "$selected" in
        *"Toggle Play/Pause"*) mpv_send '{"command": ["cycle", "pause"]}' ;;
        *"Previous Track"*)    mpv_send '{"command": ["playlist-prev"]}' ;;
        *"Next Track"*)        mpv_send '{"command": ["playlist-next"]}' ;;
        *"Volume +10%"*)       mpv_send '{"command": ["add", "volume", 10]}' ;;
        *"Volume -10%"*)       mpv_send '{"command": ["add", "volume", -10]}' ;;
        *"Mute/Unmute"*)       mpv_send '{"command": ["cycle", "mute"]}' ;;
        *"Speed -0.25x"*)      mpv_send '{"command": ["multiply", "speed", 0.8]}' ;;
        *"Speed +0.25x"*)      mpv_send '{"command": ["multiply", "speed", 1.25]}' ;;
        *"Reset Speed"*)       mpv_send '{"command": ["set", "speed", 1]}' ;;
        *"Loop Track"*)        mpv_send '{"command": ["cycle-values", "loop-file", "inf", "no"]}' ;;
        *"Loop Playlist"*)     mpv_send '{"command": ["cycle", "loop-playlist"]}' ;;
        *"Stop"*)              cmd_stop ;;
        *"Seek -10s"*)         mpv_send '{"command": ["seek", -10]}' ;;
        *"Seek +10s"*)         mpv_send '{"command": ["seek", 10]}' ;;
        *"Seek -1min"*)        mpv_send '{"command": ["seek", -60]}' ;;
        *"Seek +1min"*)        mpv_send '{"command": ["seek", 60]}' ;;
        *"Restart Track"*)     mpv_send '{"command": ["seek", "absolute", 0]}' ;;
        *"Toggle Shuffle"*)    mpv_send '{"command": ["cycle", "playlist-shuffle"]}' ;;
        *"Show Playlist"*)     cmd_select; return ;;
        *"Change"*)            cmd_change; return ;;
    esac
}

# Select a track from the current playlist
cmd_select() {
    cmd_check || exit 1

    local playlist_raw selection_list
    playlist_raw=$(mpv_send '{"command": ["get_property", "playlist"]}')
    [[ -z "$playlist_raw" ]] && exit 1

    # Parse JSON playlist: extract filename, remove path and extension, mark playing track
    selection_list=$(echo "$playlist_raw" | jq -r '
        .data | to_entries | .[] |
        "\(.key + 1). \(.value.filename | split("/")[-1] | rtrimstr("." + (. | split(".")[-1])))\(if .value.playing then " ¾░Äł" else "" end)"
    ')

    [[ -z "$selection_list" ]] && exit 0

    local selected index
    selected=$(echo "$selection_list" | tofi --prompt-text "mpv playlist: " --require-match true) || exit 0
    index="${selected%%.*}"
    [[ "$index" =~ ^[0-9]+$ ]] || exit 0

    mpv_send "{\"command\": [\"playlist-play-index\", $(( index - 1 ))]}" >/dev/null
}

# Change to a different playlist directory
cmd_change() {
    local selected
    selected=$(select_playlist_dir)
    [[ -z "$selected" ]] && return 0

    mpv_send '{"command": ["playlist-clear"]}' >/dev/null
    mpv_send "{\"command\": [\"loadlist\", \"$MUSIC_DIR/$selected/\", \"replace\"]}" >/dev/null

    wait_for_playlist || { dunstify -a "mpv-control" -u critical "mpv Error" "Playlist not loaded."; return 1; }

    dunstify -a "mpv-control" "Playlist Changed" "Loaded: $selected"
    cmd_select
}

# Show notifications for playback changes (runs continuously with playerctl)
cmd_noti() {
    local TEMP_DIR prev="" title artist
    TEMP_DIR=$(mktemp -d /tmp/media_notif_XXXXXXXX)
    trap 'rm -rf "$TEMP_DIR"' EXIT

    playerctl -p mpv metadata --follow --format '{{status}}|{{title}}|{{artist}}|{{mpris:artUrl}}' | \
    while IFS='|' read -r p_status title artist arturl; do
        title="${title## }"; title="${title%% }"
        artist="${artist## }"; artist="${artist%% }"
        [[ -z "$title" && -z "$artist" ]] && continue

        local cur="$title|$artist|$p_status"
        [[ "$cur" == "$prev" ]] && continue
        prev="$cur"

        local img=""
        [[ -f "$DEFAULT_IMG" ]] && img="$DEFAULT_IMG"
        [[ "$arturl" == *base64* ]] && { printf '%s' "${arturl#*,}" | base64 -d >"$TEMP_DIR/mpv-art.avif" 2>/dev/null || true; img="$TEMP_DIR/mpv-art.avif"; }

        local icon="¾░ōø"
        [[ "$p_status" == "Playing" ]] && icon="’üī"
        [[ "$p_status" == "Paused" ]] && icon="’üŗ"

        local loop_suffix
        loop_suffix=$(get_loop_suffix)

        dunstify -u low -h string:x-dunst-stack-tag:mpv -i "$img" "$icon  $title$loop_suffix" "$artist"
    done
}

# Stop mpv and clean up socket
cmd_stop() {
    [[ -S "$SOCKET" ]] && { mpv_send '{"command": ["quit"]}' >/dev/null 2>&1; sleep 0.2; }
    rm -f "$SOCKET" 2>/dev/null
    pkill mpv 2>/dev/null || true
    dunstify -a "mpv-control" -u low -h string:x-dunst-stack-tag:mpv "’üŹ Stopped"
}

# Show help
cmd_help() {
    print "Usage: bplayer [command]

Commands:
  start     - Launch mpv with playlist selection
  actions   - Show playback control menu
  select    - Select a track from current playlist
  change    - Change to a different playlist
  stop      - Stop mpv and clean up socket
  noti      - Show notifications for playback (run with &)
  check     - Check if mpv is running (returns 0 if yes)
  help      - Show this help message

Note: Running 'bplayer' without arguments will:
  - Start mpv with playlist selection if not running
  - Change playlist if mpv is already running"
}

# Main entry point
if [[ $# -eq 0 ]]; then
    if cmd_check 2>/dev/null; then
        cmd_change
    else
        cmd_start
    fi
else
    case "$1" in
        start)   cmd_start ;;
        actions) cmd_actions ;;
        select)  cmd_select ;;
        change)  cmd_change ;;
        stop)    cmd_stop ;;
        noti)    cmd_noti ;;
        check)   cmd_check ;;
        help)    cmd_help ;;
        *)       print -u2 "Unknown command: $1"; cmd_help; exit 1 ;;
    esac
fi
