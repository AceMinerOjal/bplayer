#!/bin/zsh
# bplayer - Unified mpv player control script for Arch Linux
# Usage: bplayer [command]

set -eu
set -o pipefail

# Configuration via environment variables (with defaults)
SCRIPT_DIR="${0:A:h}"
SOCKET="${BPLAYER_SOCKET:-${XDG_RUNTIME_DIR:-/tmp}/mpvsocket}"
DEFAULT_IMG="${BPLAYER_DEFAULT_IMG:-}"
MUSIC_DIR="${BPLAYER_MUSIC_DIR:-$HOME/Music}"
typeset -gi MPV_REQUEST_ID=0

zmodload zsh/net/socket

if [[ -z "$DEFAULT_IMG" ]]; then
    if [[ -f /usr/local/share/bplayer/no-image-found.svg ]]; then
        DEFAULT_IMG="/usr/local/share/bplayer/no-image-found.svg"
    else
        DEFAULT_IMG="$SCRIPT_DIR/no-image-found.svg"
    fi
fi

notify_msg() {
    dunstify -a "mpv-control" "$@"
}

notify_error() {
    notify_msg -u critical "mpv Error" "$1"
}

trim_whitespace() {
    local value="${1-}"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    print -r -- "$value"
}

socket_exists() {
    [[ -S "$SOCKET" ]]
}

# Check if mpv is running and socket exists
cmd_check() {
    local quiet=0
    [[ "${1:-}" == "--quiet" ]] && quiet=1

    pgrep -x mpv >/dev/null || {
        (( quiet == 1 )) || notify_error "mpv is not running."
        return 1
    }
    socket_exists || {
        (( quiet == 1 )) || notify_error "No IPC socket found."
        return 1
    }
}

mpv_exchange() {
    local payload="${1:?missing payload}"
    local request_id="${2:?missing request id}"
    local fd response

    zsocket "$SOCKET" 2>/dev/null || return 1
    fd=$REPLY
    print -u$fd -r -- "$payload"
    while read -u $fd response; do
        if printf '%s' "$response" | jq -e --argjson request_id "$request_id" '(.request_id? // -1) == $request_id' >/dev/null 2>&1; then
            print -r -- "$response"
            exec {fd}>&-
            return 0
        fi
    done
    exec {fd}>&-
    return 1
}

# Send command to mpv via IPC socket
mpv_send() {
    local request_id payload
    ((MPV_REQUEST_ID += 1))
    request_id=$MPV_REQUEST_ID

    payload=$(printf '%s' "$1" | jq -c --argjson request_id "$request_id" '. + {request_id: $request_id}') || return 1
    mpv_exchange "$payload" "$request_id"
}

# Wait for socket to be created (max 2 seconds)
socket_wait() {
    local attempt=0
    while ! socket_exists && [[ $attempt -lt 20 ]]; do
        sleep 0.1
        ((attempt++))
    done
    socket_exists || return 1
}

# Wait for playlist to be loaded (max 5 seconds)
wait_for_playlist() {
    local attempt=0 playlist
    while [[ $attempt -lt 50 ]]; do
        playlist=$(mpv_send '{"command": ["get_property", "playlist"]}' 2>/dev/null)
        if [[ -n "$playlist" ]] && printf '%s' "$playlist" | jq -e '.data | length > 0 and .[0].filename != null' >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.1
        ((attempt++))
    done
    return 1
}

# Show playlist directory selector
select_playlist_dir() {
    [[ -d "$MUSIC_DIR" ]] || {
        notify_error "Music directory not found: $MUSIC_DIR"
        return 1
    }

    local choices
    choices=$(find "$MUSIC_DIR" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort)
    [[ -n "$choices" ]] || {
        notify_error "No playlists found in: $MUSIC_DIR"
        return 1
    }

    print -r -- "$choices" | tofi --prompt-text "Select playlist: "
}

# Return sorted media files for a playlist directory.
playlist_files() {
    local playlist_dir="${1:?missing playlist dir}"
    find "$playlist_dir" -maxdepth 1 -type f \
        \( -iname '*.aac' -o -iname '*.alac' -o -iname '*.flac' -o -iname '*.m4a' -o -iname '*.mp3' -o -iname '*.ogg' -o -iname '*.opus' -o -iname '*.wav' -o -iname '*.weba' -o -iname '*.wma' -o -iname '*.mp4' -o -iname '*.mkv' -o -iname '*.webm' \) \
        | sort
}

start_mpv() {
    local -a files=("$@")

    socket_exists && mpv_send '{"command": ["quit"]}' >/dev/null 2>&1 || true
    rm -f "$SOCKET" 2>/dev/null || true

    mpv --no-video --no-terminal --input-ipc-server="$SOCKET" "${files[@]}" 2>/dev/null &
    socket_wait || return 1
    wait_for_playlist || return 1
}

load_playlist_into_mpv() {
    local file payload mode="replace"
    local -a files=("$@")

    mpv_send '{"command": ["playlist-clear"]}' >/dev/null
    for file in "${files[@]}"; do
        payload=$(jq -nc --arg file "$file" --arg mode "$mode" '{"command": ["loadfile", $file, $mode]}')
        mpv_send "$payload" >/dev/null
        mode="append"
    done

    wait_for_playlist
}

# Get loop status (internal helper)
_get_loop_status() {
    local loop_file loop_playlist
    loop_file=$(mpv_send '{"command": ["get_property", "loop-file"]}' 2>/dev/null | jq -r '.data // "no"')
    loop_playlist=$(mpv_send '{"command": ["get_property", "loop-playlist"]}' 2>/dev/null | jq -r '.data // "false"')
    print "$loop_file|$loop_playlist"
}

# Get loop status indicators for menu display
get_loop_indicators() {
    local loop_data loop_file loop_playlist file_ind="" playlist_ind=""
    loop_data=$(_get_loop_status)
    loop_file="${loop_data%%|*}"
    loop_playlist="${loop_data##*|}"
    [[ "$loop_file" != "no" && "$loop_file" != "false" ]] && file_ind=" ÔÄ°"
    [[ "$loop_playlist" != "false" && "$loop_playlist" != "0" ]] && playlist_ind=" ÔÄû"
    print "$file_ind|$playlist_ind"
}

# Build loop suffix for notifications
get_loop_suffix() {
    socket_exists || return 0
    local loop_data loop_file loop_playlist suffix=""
    loop_data=$(_get_loop_status)
    loop_file="${loop_data%%|*}"
    loop_playlist="${loop_data##*|}"
    [[ "$loop_file" != "no" && "$loop_file" != "false" ]] && suffix+=" ÔÄ°"
    [[ "$loop_playlist" != "false" && "$loop_playlist" != "0" ]] && suffix+=" ÔÄû"
    print "$suffix"
}

# Launch mpv with playlist selection, then open track selector
cmd_start() {
    local selected playlist_dir
    local -a files
    selected=$(select_playlist_dir) || exit 1
    [[ -z "$selected" ]] && exit 0
    playlist_dir="$MUSIC_DIR/$selected"
    files=("${(@f)$(playlist_files "$playlist_dir")}")
    [[ ${#files[@]} -gt 0 ]] || { notify_error "No tracks found in: $selected"; exit 1; }

    start_mpv "${files[@]}" || { notify_error "Failed to start mpv or load playlist."; exit 1; }
    cmd_select
}

# Show playback control menu
cmd_actions() {
    cmd_check || exit 1

    local loop_status loop_file_ind loop_playlist_ind
    loop_status=$(get_loop_indicators)
    loop_file_ind="${loop_status%%|*}"
    loop_playlist_ind="${loop_status##*|}"

    local selected
    selected=$(printf '%s\n' "ÔÅã Toggle Play/Pause" "Û∞íÆ Previous Track" "Û∞í≠ Next Track" "ÔÄ® Volume +10%" "ÔÄß Volume -10%" "ÔÄ¶ Mute/Unmute" "ÔâÜ Speed -0.25x" "ÔâÜ Speed +0.25x" "ÔÄû Reset Speed" "${loop_file_ind} Loop Track" "${loop_playlist_ind} Loop Playlist" "ÔÄë Stop" "ÔÅÝ Seek -10s" "ÔÅ° Seek +10s" "Û∞ëê Seek -1min" "Û∞ëî Seek +1min" "ÔÄ° Restart Track" "Û∞ìÄ Toggle Shuffle" "ÔÑæ Show Playlist" "ÔÄï Change" \
        | tofi --prompt-text "Select action: ")

    case "$selected" in
        *"Toggle Play/Pause"*) mpv_send '{"command": ["cycle", "pause"]}' ;;
        *"Previous Track"*)    mpv_send '{"command": ["playlist-prev"]}' ;;
        *"Next Track"*)        mpv_send '{"command": ["playlist-next"]}' ;;
        *"Volume +10%"*)       mpv_send '{"command": ["add", "volume", 10]}' ;;
        *"Volume -10%"*)       mpv_send '{"command": ["add", "volume", -10]}' ;;
        *"Mute/Unmute"*)       mpv_send '{"command": ["cycle", "mute"]}' ;;
        *"Speed -0.25x"*)      mpv_send '{"command": ["multiply", "speed", 0.8]}' ;;
        *"Speed +0.25x"*)      mpv_send '{"command": ["multiply", "speed", 1.25]}' ;;
        *"Reset Speed"*)       mpv_send '{"command": ["set", "speed", 1]}' ;;
        *"Loop Track"*)        mpv_send '{"command": ["cycle-values", "loop-file", "inf", "no"]}' ;;
        *"Loop Playlist"*)     mpv_send '{"command": ["cycle", "loop-playlist"]}' ;;
        *"Stop"*)              cmd_stop ;;
        *"Seek -10s"*)         mpv_send '{"command": ["seek", -10]}' ;;
        *"Seek +10s"*)         mpv_send '{"command": ["seek", 10]}' ;;
        *"Seek -1min"*)        mpv_send '{"command": ["seek", -60]}' ;;
        *"Seek +1min"*)        mpv_send '{"command": ["seek", 60]}' ;;
        *"Restart Track"*)     mpv_send '{"command": ["seek", 0, "absolute"]}' ;;
        *"Toggle Shuffle"*)    mpv_send '{"command": ["playlist-shuffle"]}' ;;
        *"Show Playlist"*)     cmd_select; return ;;
        *"Change"*)            cmd_change; return ;;
    esac
}

# Select a track from the current playlist
cmd_select() {
    cmd_check || exit 1

    local playlist_raw selection_list
    playlist_raw=$(mpv_send '{"command": ["get_property", "playlist"]}')
    [[ -z "$playlist_raw" ]] && exit 1

    selection_list=$(printf '%s' "$playlist_raw" | jq -r '
        .data | to_entries | .[] |
        "\(.key + 1). \((.value.title // (.value.filename | split("/")[-1])) | sub("\\.[^.]+$"; ""))\(if .value.playing then " Û∞éà" else "" end)"
    ')

    [[ -z "$selection_list" ]] && exit 0

    local selected index
    selected=$(print -r -- "$selection_list" | tofi --prompt-text "mpv playlist: " --require-match true) || exit 0
    index="${selected%%.*}"
    [[ "$index" =~ ^[0-9]+$ ]] || exit 0

    mpv_send "{\"command\": [\"playlist-play-index\", $(( index - 1 ))]}" >/dev/null
}

# Change to a different playlist directory
cmd_change() {
    cmd_check || return 1

    local selected playlist_dir
    local -a files
    selected=$(select_playlist_dir) || return 1
    [[ -z "$selected" ]] && return 0
    playlist_dir="$MUSIC_DIR/$selected"
    files=("${(@f)$(playlist_files "$playlist_dir")}")
    [[ ${#files[@]} -gt 0 ]] || { notify_error "No tracks found in: $selected"; return 1; }

    load_playlist_into_mpv "${files[@]}" || { notify_error "Playlist not loaded."; return 1; }

    notify_msg "Playlist Changed" "Loaded: $selected"
    cmd_select
}

# Show notifications for playback changes (runs continuously with playerctl)
cmd_noti() {
    local TEMP_DIR prev="" title artist arturl p_status
    TEMP_DIR=$(mktemp -d /tmp/media_notif_XXXXXXXX)
    trap "rm -rf '$TEMP_DIR'" EXIT

    playerctl -p mpv metadata --follow --format '{{status}}|{{title}}|{{artist}}|{{mpris:artUrl}}' | \
    while IFS='|' read -r p_status title artist arturl; do
        title=$(trim_whitespace "$title")
        artist=$(trim_whitespace "$artist")
        [[ -z "$title" && -z "$artist" ]] && continue

        local cur="$title|$artist|$p_status"
        [[ "$cur" == "$prev" ]] && continue
        prev="$cur"

        local img=""
        [[ -f "$DEFAULT_IMG" ]] && img="$DEFAULT_IMG"
        if [[ "$arturl" == *base64* ]]; then
            printf '%s' "${arturl#*,}" | base64 -d >"$TEMP_DIR/mpv-art" 2>/dev/null || true
            [[ -s "$TEMP_DIR/mpv-art" ]] && img="$TEMP_DIR/mpv-art"
        elif [[ "$arturl" == file://* ]]; then
            local decoded_path="${arturl#file://}"
            decoded_path="${decoded_path//%20/ }"
            [[ -f "$decoded_path" ]] && img="$decoded_path"
        elif [[ -f "$arturl" ]]; then
            img="$arturl"
        fi

        local icon="Û∞ìõ"
        [[ "$p_status" == "Playing" ]] && icon="ÔÅå"
        [[ "$p_status" == "Paused" ]] && icon="ÔÅã"

        local loop_suffix
        loop_suffix=$(get_loop_suffix)

        dunstify -u low -h string:x-dunst-stack-tag:mpv -i "$img" "$icon  $title$loop_suffix" "$artist"
    done
}

# Stop mpv and clean up socket
cmd_stop() {
    socket_exists && { mpv_send '{"command": ["quit"]}' >/dev/null 2>&1; sleep 0.2; }
    rm -f "$SOCKET" 2>/dev/null
    pkill mpv 2>/dev/null || true
    notify_msg -u low -h string:x-dunst-stack-tag:mpv "ÔÅç Stopped"
}

# Show help
cmd_help() {
    print "Usage: bplayer [command]

Commands:
  start     - Launch mpv with playlist selection
  actions   - Show playback control menu
  select    - Select a track from current playlist
  change    - Change to a different playlist
  stop      - Stop mpv and clean up socket
  noti      - Show notifications for playback (run with &)
  check     - Check if mpv is running (returns 0 if yes)
  help      - Show this help message

Note: Running 'bplayer' without arguments will:
  - Start mpv with playlist selection if not running
  - Change playlist if mpv is already running"
}

main() {
    if [[ $# -eq 0 ]]; then
        if cmd_check --quiet 2>/dev/null; then
            cmd_change
        else
            cmd_start
        fi
        return 0
    fi

    case "$1" in
        start)   cmd_start ;;
        actions) cmd_actions ;;
        select)  cmd_select ;;
        change)  cmd_change ;;
        stop)    cmd_stop ;;
        noti)    cmd_noti ;;
        check)   cmd_check ;;
        help)    cmd_help ;;
        *)       print -u2 "Unknown command: $1"; cmd_help; return 1 ;;
    esac
}

if [[ "${BPLAYER_SOURCE_ONLY:-0}" != 1 ]]; then
    main "$@"
fi
